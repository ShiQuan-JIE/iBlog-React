// Prisma Schema - iBlog 数据模型
// 数据库：PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 管理员（后台登录用户）
// ============================================
model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// 博客用户（评论/留言者）
// ============================================
model User {
  id        Int       @id @default(autoincrement())
  nickName  String
  email     String?
  url       String?
  avatarImg String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
  messages  Message[]
}

// ============================================
// 文章分类
// ============================================
model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  articles Article[] @relation("ArticleCategories")
}

// ============================================
// 文章
// ============================================
model Article {
  id         Int        @id @default(autoincrement())
  title      String
  icon       String?    // 缩略图 URL
  body       String     @db.Text  // Markdown 内容
  views      Int        @default(0)
  msgs       Int        @default(0) // 评论数
  categories Category[] @relation("ArticleCategories")
  comments   Comment[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// ============================================
// 文章评论（支持楼中楼）
// ============================================
model Comment {
  id           Int       @id @default(autoincrement())
  nickName     String
  avatarImg    String?
  content      String    @db.Text
  byAiteName   String?   // @ 的用户名
  parentId     Int?      // 父评论 ID（自引用实现楼中楼）
  parent       Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies      Comment[] @relation("CommentReplies")
  userId       Int?
  user         User?     @relation(fields: [userId], references: [id])
  articleId    Int?
  article      Article?  @relation(fields: [articleId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ============================================
// 友链
// ============================================
model Link {
  id          Int      @id @default(autoincrement())
  name        String
  site        String
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// 留言板（支持楼中楼）
// ============================================
model Message {
  id         Int       @id @default(autoincrement())
  nickName   String
  avatarImg  String?
  content    String    @db.Text
  byAiteName String?
  parentId   Int?
  parent     Message?  @relation("MessageReplies", fields: [parentId], references: [id])
  replies    Message[] @relation("MessageReplies")
  userId     Int?
  user       User?     @relation(fields: [userId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
