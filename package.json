{
  "name": "iblog-react",
  "version": "1.0.0",
  "description": "iBlog 前后端分离博客系统（React 19 + Express + Prisma + PostgreSQL）",
  "scripts": {
    "install-all": "npm-run-all server-install admin-install web-install",
    "server-install": "cd server && npm i",
    "admin-install": "cd admin && npm i",
    "web-install": "cd web && npm i",
    "dev-all": "npm-run-all -p server-dev admin-dev web-dev",
    "server-dev": "cd server && npm run dev",
    "admin-dev": "cd admin && npm run dev",
    "web-dev": "cd web && npm run dev",
    "build-all": "npm-run-all -p admin-build web-build",
    "admin-build": "cd admin && npm run build",
    "web-build": "cd web && npm run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
